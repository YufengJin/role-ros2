[
    {
        "name": "Franka Robot (Real)",
        "container": "ros2_polymetis_container",
        "command": "ros2 launch role_ros2 franka_robot.launch.py use_mock:=false",
        "kill_keyword": "franka_robot.launch.py use_mock:=false"
    },
    {
        "name": "Franka Robot (Mock)",
        "container": "ros2_polymetis_container",
        "command": "ros2 launch role_ros2 franka_robot.launch.py use_mock:=true",
        "kill_keyword": "franka_robot.launch.py use_mock:=true"
    },
    {
        "name": "ZED Hand (Low Res)",
        "container": "ros2_cu118_container",
        "command": "ros2 launch role_ros2 zed_camera.launch.py config_file:=hand_zed_low_res.yaml",
        "kill_keyword": "config_file:=hand_zed_low_res.yaml"
    },
    {
        "name": "ZED Static (Low Res)",
        "container": "ros2_cu118_container",
        "command": "ros2 launch role_ros2 zed_camera.launch.py config_file:=static_zed_low_res.yaml",
        "kill_keyword": "config_file:=static_zed_low_res.yaml"
    },
    {
        "name": "ZED Hand (High Res)",
        "container": "ros2_cu118_container",
        "command": "ros2 launch role_ros2 zed_camera.launch.py config_file:=hand_zed_high_res.yaml",
        "kill_keyword": "config_file:=hand_zed_high_res.yaml"
    },
    {
        "name": "ZED Static (High Res)",
        "container": "ros2_cu118_container",
        "command": "ros2 launch role_ros2 zed_camera.launch.py config_file:=static_zed_high_res.yaml",
        "kill_keyword": "config_file:=static_zed_high_res.yaml"
    },
    {
        "name": "Rviz2",
        "container": "ros2_cu118_container",
        "command": "cd /app/ros2_ws/src/role-ros2 && ros2 run rviz2 rviz2 -d config/rviz/collect_traj.rviz",
        "kill_keyword": "rviz2 -d config/rviz/collect_traj.rviz"
    },
    {
        "name": "Collect Trajectory",
        "container": "ros2_cu118_container",
        "command": "cd /app/ros2_ws/src/role-ros2 && python3 scripts/collect_trajectory_franka.py --viz --randomize-reset --mirror",
        "kill_keyword": "scripts/collect_trajectory_franka.py --viz --randomize-reset --mirror"
    }
]
