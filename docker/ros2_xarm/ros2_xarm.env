#!/bin/bash
# ros2_xarm.env - Environment setup for ROS2 Humble + xArm Python SDK
#
# Source this after entering the container to (re)apply settings:
#   source /etc/ros2_xarm/ros2_xarm.env

# ============================================================================
# ROS2 Humble
# ============================================================================
if [ -f "/opt/ros/humble/setup.bash" ]; then
    source /opt/ros/humble/setup.bash
    [ -t 0 ] && echo "ROS2 Humble environment sourced"
else
    [ -t 0 ] && echo "Warning: ROS2 Humble not found at /opt/ros/humble/setup.bash"
fi

# ============================================================================
# ROS2 workspace overlay
# ============================================================================
if [ -f "/app/ros2_ws/install/setup.bash" ]; then
    source /app/ros2_ws/install/setup.bash
    [ -t 0 ] && echo "ROS2 workspace sourced from /app/ros2_ws/install/setup.bash"
else
    [ -t 0 ] && echo "Note: ROS2 workspace not built yet. Run 'colcon build' under /app/ros2_ws."
fi

# ============================================================================
# xArm robot configuration
# ============================================================================
export ROBOT_IP=${ROBOT_IP:-192.168.1.222}

# ============================================================================
# ROS2 DDS configuration
# ============================================================================
export ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-0}
export RMW_IMPLEMENTATION=${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}
export ROS_LOCALHOST_ONLY=${ROS_LOCALHOST_ONLY:-0}
export FASTDDS_BUILTIN_TRANSPORTS=${FASTDDS_BUILTIN_TRANSPORTS:-UDPv4}

# ============================================================================
# Logging
# ============================================================================
export RCUTILS_LOGGING_SEVERITY=${RCUTILS_LOGGING_SEVERITY:-INFO}
export RCUTILS_LOGGING_USE_STDOUT=1

# ============================================================================
# Display / X11
# ============================================================================
export DISPLAY=${DISPLAY:-:0}

# ============================================================================
# Summary (interactive shells only)
# ============================================================================
if [ -t 0 ]; then
    XARM_VERSION=$(python3 -c "import xarm; print(xarm.version.__version__)" 2>/dev/null || echo "not installed")
    echo ""
    echo "============================================================================"
    echo "ros2_xarm environment"
    echo "============================================================================"
    echo "ROS2 Distribution:    ${ROS_DISTRO:-humble}"
    echo "ROS2 Workspace:       /app/ros2_ws"
    echo "Python:               $(python3 --version 2>/dev/null)"
    echo "xarm-python-sdk:      ${XARM_VERSION}"
    echo "ROBOT_IP:             ${ROBOT_IP}"
    echo "ROS_DOMAIN_ID:        ${ROS_DOMAIN_ID}"
    echo "RMW_IMPLEMENTATION:   ${RMW_IMPLEMENTATION}"
    echo "ROS_LOCALHOST_ONLY:   ${ROS_LOCALHOST_ONLY}"
    if [ "${ROS_LOCALHOST_ONLY}" = "1" ]; then
        echo "Warning: ROS_LOCALHOST_ONLY=1, external communication disabled"
    fi
    echo "============================================================================"
    echo ""
    echo "Quick smoke test:     /smoke_test.sh"
    echo "Rebuild workspace:    cd /app/ros2_ws && colcon build --symlink-install"
    echo ""
fi
