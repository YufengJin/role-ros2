<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
    <Domain id="any">
        <General>
            <!-- Enable multicast for DDS discovery -->
            <AllowMulticast>true</AllowMulticast>
            <!-- Enable multicast loopback for local communication -->
            <EnableMulticastLoopback>true</EnableMulticastLoopback>
            <!-- Note: NetworkInterfaceAddress is deprecated in CycloneDDS for ROS2 Humble -->
            <!-- CycloneDDS will automatically select the appropriate network interface -->
            <!-- For multi-NIC environments, use environment variable CYCLONEDDS_URI with interface override if needed -->
        </General>
        <Discovery>
            <!-- Auto-assign participant index -->
            <ParticipantIndex>auto</ParticipantIndex>
            <!-- Maximum auto participant index (allows up to 120 participants) -->
            <MaxAutoParticipantIndex>120</MaxAutoParticipantIndex>
        </Discovery>
    </Domain>
</CycloneDDS>

