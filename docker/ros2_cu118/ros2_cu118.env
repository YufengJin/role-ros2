#!/bin/bash
# ros2_cu118.env - Environment setup script for ROS2 Humble with CUDA 11.8
# 
# This script configures the environment for ROS2 Humble.
# Source this file after entering the docker container:
#   source /app/ros2_ws/src/role-ros2/docker/ros2_cu118/ros2_cu118.env
#
# This allows you to rebuild ros2_ws multiple times without rebuilding the docker image.

# ============================================================================
# ROS2 Humble Setup
# ============================================================================
# Note: This is already sourced in entrypoint.sh
# Only source here if manually using this file (not from entrypoint.sh)
if [ -f "/opt/ros/humble/setup.bash" ]; then
    source /opt/ros/humble/setup.bash
    [ -t 0 ] && echo "✓ ROS2 Humble environment sourced"
else
    [ -t 0 ] && echo "⚠️  Warning: ROS2 Humble not found at /opt/ros/humble/setup.bash"
fi

# ============================================================================
# ROS2 Workspace Setup
# ============================================================================
# Note: This is already sourced in entrypoint.sh
# Only source here if manually using this file (not from entrypoint.sh)
if [ -f "/app/ros2_ws/install/setup.bash" ]; then
    source /app/ros2_ws/install/setup.bash
    [ -t 0 ] && echo "✓ ROS2 workspace sourced from /app/ros2_ws/install/setup.bash"
else
    [ -t 0 ] && echo "⚠️  Warning: ROS2 workspace is not built. Please run:"
    [ -t 0 ] && echo "    colcon build --symlink-install && source /app/ros2_ws/install/setup.bash"
fi

# ============================================================================
# Library Paths Configuration
# ============================================================================
export LD_LIBRARY_PATH=/opt/ros/humble/lib:/opt/ros/humble/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH}

# ============================================================================
# Robot Configuration
# ============================================================================
export ROBOT_IP=${ROBOT_IP:-172.17.0.2}
export NUC_IP=${NUC_IP:-172.17.0.1}
export LAPTOP_IP=${LAPTOP_IP:-172.17.0.1}
export ROBOT_TYPE=${ROBOT_TYPE:-fr3}

# ============================================================================
# ROS2 DDS Configuration
# ============================================================================
# ROS2 Domain ID (must be identical across all devices for communication)
export ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-0}

# RMW Implementation (must be consistent across all nodes)
# Using FastRTPS (matches official image, verified to work)
# To switch back to CycloneDDS, set to: rmw_cyclonedds_cpp
export RMW_IMPLEMENTATION=${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}

# ROS Localhost Only (set to 0 for multi-machine communication)
# WARNING: If set to 1, external communication will fail
export ROS_LOCALHOST_ONLY=${ROS_LOCALHOST_ONLY:-0}

# CycloneDDS Configuration (disabled, using FastRTPS)
# If you need to switch back to CycloneDDS in the future, uncomment the following:
# CYCLONEDDS_XML_PATH="/app/ros2_ws/src/role-ros2/docker/ros2_cu118/cyclonedds.xml"
# if [ -f "$CYCLONEDDS_XML_PATH" ]; then
#     export CYCLONEDDS_URI="file://${CYCLONEDDS_XML_PATH}"
#     [ -t 0 ] && echo "✓ CycloneDDS configuration file loaded: ${CYCLONEDDS_URI}"
# fi

# Optional: CycloneDDS Logging (set to 1-6 for debug, 0 to disable)
# export CYCLONEDDS_LOG_LEVEL=${CYCLONEDDS_LOG_LEVEL:-0}

# ============================================================================
# ROS2 Logging Configuration
# ============================================================================
export RCUTILS_LOGGING_SEVERITY=${RCUTILS_LOGGING_SEVERITY:-INFO}
export RCUTILS_LOGGING_USE_STDOUT=1

# ============================================================================
# CUDA Configuration (if needed)
# ============================================================================
if [ -n "$CUDA_VISIBLE_DEVICES" ]; then
    export CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES}
    echo "✓ CUDA_VISIBLE_DEVICES: ${CUDA_VISIBLE_DEVICES}"
fi

# ============================================================================
# Summary (only show if manually sourced, not from entrypoint.sh)
# ============================================================================
# Only show summary if this file is manually sourced (interactive terminal)
if [ -t 0 ]; then
    echo ""
    echo "============================================================================"
    echo "Environment Configuration Summary"
    echo "============================================================================"
    echo "ROS2 Distribution:    ROS2 ${ROS_VERSION:-2} ${ROS_DISTRO:-Unknown}"
    echo "ROS2 Workspace:        /app/ros2_ws"
    echo "ZED SDK:               ${ZED_SDK_MAJOR:-?}.${ZED_SDK_MINOR:-?}"
    echo "ZED ROS2 Wrapper:      ${ZED_ROS2_WRAPPER_VERSION:-unknown}"
    echo "ROS_DOMAIN_ID:         ${ROS_DOMAIN_ID}"
echo "RMW_IMPLEMENTATION:    ${RMW_IMPLEMENTATION}"
echo "CYCLONEDDS_URI:        ${CYCLONEDDS_URI:-Not set (using default configuration)}"
echo "ROS_LOCALHOST_ONLY:    ${ROS_LOCALHOST_ONLY}"
if [ "${ROS_LOCALHOST_ONLY}" = "1" ]; then
    echo "⚠️  Warning: ROS_LOCALHOST_ONLY=1, external communication will be disabled"
fi
echo "============================================================================"
echo ""
echo "💡 To manually rebuild ROS2 workspace (e.g., when developing via volume mount):"
echo "    colcon build --symlink-install"
echo "    source /app/ros2_ws/install/setup.bash"
echo ""
fi

