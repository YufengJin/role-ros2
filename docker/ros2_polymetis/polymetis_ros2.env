#!/bin/bash
# polymetis_ros2.env - Environment setup script for Polymetis + ROS2 Foxy
# 
# This script configures the environment for Polymetis and ROS2 Foxy.
# Source this file after entering the docker container:
#   source /app/ros2_ws/src/role-ros2/docker/polymetis_ros2.env
#
# This allows you to rebuild ros2_ws multiple times without rebuilding the docker image.

# ============================================================================
# Git Configuration (for Polymetis version detection)
# ============================================================================
# Note: In ros2_polymetis, entire fairo directory is copied to /opt/fairo
# This includes the .git directory, so version detection works automatically
git config --global --add safe.directory /opt/fairo 2>/dev/null || true

# ============================================================================
# ROS2 Foxy Setup
# ============================================================================
if [ -f "/opt/ros/foxy/setup.bash" ]; then
    source /opt/ros/foxy/setup.bash
    echo "✓ ROS2 Foxy environment sourced"
else
    echo "⚠️  Warning: ROS2 Foxy not found at /opt/ros/foxy/setup.bash"
fi

# ============================================================================
# ROS2 Workspace Setup
# ============================================================================
if [ -f "/app/ros2_ws/install/setup.bash" ]; then
    source /app/ros2_ws/install/setup.bash
    echo "✓ ROS2 workspace sourced from /app/ros2_ws/install/setup.bash"
else
    echo "⚠️  Warning: ROS2 workspace not built yet. Run 'colcon build' first."
fi

# ============================================================================
# Micromamba/Conda Environment Setup
# ============================================================================
# Initialize micromamba if not already initialized
if ! command -v micromamba &> /dev/null; then
    echo "⚠️  Warning: micromamba not found in PATH"
else
    # Initialize micromamba shell hook
    eval "$(micromamba shell hook --shell bash)" 2>/dev/null || true
    
    # Activate polymetis-local environment
    if micromamba env list | grep -q "polymetis-local"; then
        micromamba activate polymetis-local
        echo "✓ Micromamba environment 'polymetis-local' activated"
    else
        echo "⚠️  Warning: polymetis-local environment not found"
    fi
fi

# ============================================================================
# Library Paths Configuration
# ============================================================================
# Prioritize system spdlog over conda libraries to avoid conflicts
export LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:/opt/ros/foxy/lib:/opt/ros/foxy/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH}
export LD_LIBRARY_PATH=${LD_LIBRARY_PATH}:/opt/openrobots/lib

# Add conda environment libraries if conda is active
if [ -n "$CONDA_PREFIX" ]; then
    export LD_LIBRARY_PATH=${LD_LIBRARY_PATH}:$CONDA_PREFIX/lib
fi

# ============================================================================
# CMAKE and PKG_CONFIG Paths (for building)
# ============================================================================
export CMAKE_PREFIX_PATH=/opt/openrobots:/opt/ros/foxy:${CMAKE_PREFIX_PATH}
if [ -n "$CONDA_PREFIX" ]; then
    export CMAKE_PREFIX_PATH=${CMAKE_PREFIX_PATH}:$CONDA_PREFIX
fi

export PKG_CONFIG_PATH=/opt/openrobots/lib/pkgconfig:${PKG_CONFIG_PATH}
if [ -n "$CONDA_PREFIX" ]; then
    export PKG_CONFIG_PATH=${PKG_CONFIG_PATH}:$CONDA_PREFIX/lib/pkgconfig
fi

# ============================================================================
# Robot and Polymetis Configuration
# ============================================================================
export ROBOT_IP=${ROBOT_IP:-172.17.0.2}
export POLYMETIS_IP=${POLYMETIS_IP:-127.0.0.1}

# ============================================================================
# ROS2 DDS Configuration
# ============================================================================
export ROS_DOMAIN_ID=${ROS_DOMAIN_ID:-0}
export RMW_IMPLEMENTATION=${RMW_IMPLEMENTATION:-rmw_cyclonedds_cpp}
export ROS_LOCALHOST_ONLY=${ROS_LOCALHOST_ONLY:-0}

# Set DDS config based on RMW implementation
if [ "$RMW_IMPLEMENTATION" = "rmw_cyclonedds_cpp" ]; then
    CYCLONE_CONFIG="/app/ros2_ws/src/role-ros2/docker/cyclonedds.xml"
    if [ -f "$CYCLONE_CONFIG" ]; then
        export CYCLONEDDS_URI="file://$CYCLONE_CONFIG"
        echo "✓ CycloneDDS configured: $CYCLONEDDS_URI"
    fi
elif [ "$RMW_IMPLEMENTATION" = "rmw_fastrtps_cpp" ]; then
    PROFILE_PATH="/app/ros2_ws/src/role-ros2/docker/fastrtps_profile.xml"
    if [ -f "$PROFILE_PATH" ]; then
        export FASTRTPS_DEFAULT_PROFILES_FILE="$PROFILE_PATH"
        echo "✓ FastRTPS configured: $FASTRTPS_DEFAULT_PROFILES_FILE"
    fi
fi

# ============================================================================
# ROS2 Logging Configuration
# ============================================================================
export RCUTILS_LOGGING_SEVERITY=${RCUTILS_LOGGING_SEVERITY:-INFO}
export RCUTILS_LOGGING_USE_STDOUT=1

# ============================================================================
# Python Path Configuration
# ============================================================================
# Add ROS2 workspace Python packages to PYTHONPATH
# Note: ROS2 messages/services are automatically installed by rosidl_generate_interfaces
# to the correct location (which may vary by ROS2 version). The manual Python package
# (role_ros2) is installed to the standard site-packages location.
# source install/setup.bash should already set the correct PYTHONPATH, but we add it
# here as a backup for cases where setup.bash is not sourced.
if [ -d "/app/ros2_ws/install/role_ros2/lib/python3.8/site-packages" ]; then
    export PYTHONPATH=/app/ros2_ws/install/role_ros2/lib/python3.8/site-packages:${PYTHONPATH}
fi

# ============================================================================
# Summary
# ============================================================================
echo ""
echo "============================================================================"
echo "Environment Configuration Summary"
echo "============================================================================"
echo "ROS2 Distribution:    $(ros2 --version 2>/dev/null | head -1 || echo 'Not available')"
echo "ROS2 Workspace:        /app/ros2_ws"
echo "Conda Environment:     ${CONDA_DEFAULT_ENV:-not activated}"
echo "Conda Prefix:          ${CONDA_PREFIX:-not set}"
echo "ROBOT_IP:              ${ROBOT_IP}"
echo "POLYMETIS_IP:          ${POLYMETIS_IP}"
echo "ROS_DOMAIN_ID:         ${ROS_DOMAIN_ID}"
echo "RMW_IMPLEMENTATION:    ${RMW_IMPLEMENTATION}"
echo "============================================================================"
echo ""

