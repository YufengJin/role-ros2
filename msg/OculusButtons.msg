# Oculus Quest Controller Buttons Message
std_msgs/Header header

# Boolean buttons
bool a
bool b
bool x
bool y
bool right_thumb_up
bool left_thumb_up
bool right_joystick_pressed
bool left_joystick_pressed
bool right_grip_pressed
bool left_grip_pressed
bool right_trigger_pressed
bool left_trigger_pressed

# Analog values (0.0 - 1.0)
float32 right_grip_value
float32 left_grip_value
float32 right_trigger_value
float32 left_trigger_value

# Joystick positions (-1.0 to 1.0)
float32 right_joystick_x
float32 right_joystick_y
float32 left_joystick_x
float32 left_joystick_y

